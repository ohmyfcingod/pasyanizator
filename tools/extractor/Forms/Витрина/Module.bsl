// Витрина экстрактора: обзор видов, выбор состава и каталога, запуск снятия карты.
// Тяжёлые запросы — ТОЛЬКО по кнопке «Обновить статистику»; при открытии таблица пустая.

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	КаталогВыгрузки = КаталогВременныхФайлов() + "ПасьянсКарты";
	ОткрыватьКаталог = Истина;
	ПорогДокументов = 0;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура КаталогВыгрузкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	// Выбор папки требует расширения работы с файлами (в веб-клиенте не всегда подключено) —
	// подключаем асинхронно и только затем показываем диалог.
	СтандартнаяОбработка = Ложь;
	НачатьПодключениеРасширенияРаботыСФайлами(
		Новый ОписаниеОповещения("КаталогВыгрузкиПослеПодключенияРасширения", ЭтотОбъект));

КонецПроцедуры

&НаКлиенте
Процедура КаталогВыгрузкиПослеПодключенияРасширения(Подключено, ДополнительныеПараметры) Экспорт

	Если Не Подключено Тогда
		ПоказатьПредупреждение(, "Расширение работы с файлами не подключено. Укажите каталог вручную.");
		Возврат;
	КонецЕсли;
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	Диалог.Заголовок = "Каталог для выгрузки карты";
	Диалог.Каталог = КаталогВыгрузки;
	Диалог.Показать(Новый ОписаниеОповещения("КаталогВыгрузкиПослеВыбора", ЭтотОбъект));

КонецПроцедуры

&НаКлиенте
Процедура КаталогВыгрузкиПослеВыбора(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт

	Если ВыбранныеФайлы <> Неопределено И ВыбранныеФайлы.Количество() > 0 Тогда
		КаталогВыгрузки = ВыбранныеФайлы[0];
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПорогДокументовПриИзменении(Элемент)

	// Порог > 0 — авто-отметка видов, у которых документов не меньше порога; порог 0 — ручной режим.
	Если ПорогДокументов > 0 Тогда
		Для Каждого СтрокаВида Из Объект.ТаблицаВидов Цикл
			СтрокаВида.Выгружать = (СтрокаВида.Документов >= ПорогДокументов);
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбновитьСтатистику(Команда)

	ОбновитьСтатистикуНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ОтметитьВсеВиды(Команда)

	УстановитьВыгружатьВсем(Истина);

КонецПроцедуры

&НаКлиенте
Процедура СнятьВсеВиды(Команда)

	УстановитьВыгружатьВсем(Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ОтметитьСДокументами(Команда)

	Для Каждого СтрокаВида Из Объект.ТаблицаВидов Цикл
		СтрокаВида.Выгружать = (СтрокаВида.Документов > 0);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура СформироватьКарту(Команда)

	ФайлКарты = СформироватьКартуНаСервере();
	Если ЗначениеЗаполнено(ФайлКарты) Тогда
		ПоказатьОповещениеПользователя("Карта сформирована", , ФайлКарты);
		Если ОткрыватьКаталог Тогда
			НачатьПодключениеРасширенияРаботыСФайлами(
				Новый ОписаниеОповещения("ОткрытьКаталогПослеПодключения", ЭтотОбъект, КаталогФайла(ФайлКарты)));
		КонецЕсли;
	Иначе
		ПоказатьОповещениеПользователя("Карта НЕ сформирована", , "см. лог обработки во временном каталоге");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьКаталогПослеПодключения(Подключено, КаталогКарты) Экспорт

	Если Подключено И ЗначениеЗаполнено(КаталогКарты) Тогда
		НачатьЗапускПриложения(Неопределено, КаталогКарты);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВыгружатьВсем(Значение)

	Для Каждого СтрокаВида Из Объект.ТаблицаВидов Цикл
		СтрокаВида.Выгружать = Значение;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Функция КаталогФайла(ПутьФайла)

	Разделитель = СтрНайти(ПутьФайла, "\", НаправлениеПоиска.СКонца);
	Если Разделитель > 0 Тогда
		Возврат Лев(ПутьФайла, Разделитель - 1);
	КонецЕсли;
	Возврат ПутьФайла;

КонецФункции

&НаСервере
Процедура ОбновитьСтатистикуНаСервере()

	Объект.ТаблицаВидов.Очистить();
	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	ТаблицаСтатистики = Новый ТаблицаЗначений;
	ТаблицаСтатистики.Колонки.Добавить("Вид");
	ТаблицаСтатистики.Колонки.Добавить("Реквизитов");
	ТаблицаСтатистики.Колонки.Добавить("Документов");
	Для Каждого ЗаписьВитрины Из ОбъектОбработки.ДанныеВитрины() Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаСтатистики.Добавить(), ЗаписьВитрины);
	КонецЦикла;
	ТаблицаСтатистики.Сортировать("Реквизитов Убыв, Документов Убыв");
	Для Каждого СтрокаСтатистики Из ТаблицаСтатистики Цикл
		ЗаполнитьЗначенияСвойств(Объект.ТаблицаВидов.Добавить(), СтрокаСтатистики);
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция СформироватьКартуНаСервере()

	ПараметрыВызова = Новый Структура;

	// Состав: отмеченные виды; если не отмечено ни одного — все виды из таблицы.
	ИменаВидов = Новый Массив;
	ЕстьОтмеченные = Ложь;
	Для Каждого СтрокаВида Из Объект.ТаблицаВидов Цикл
		Если СтрокаВида.Выгружать Тогда
			ИменаВидов.Добавить(СтрокаВида.Вид);
			ЕстьОтмеченные = Истина;
		КонецЕсли;
	КонецЦикла;
	Если Не ЕстьОтмеченные Тогда
		Для Каждого СтрокаВида Из Объект.ТаблицаВидов Цикл
			ИменаВидов.Добавить(СтрокаВида.Вид);
		КонецЦикла;
	КонецЕсли;
	Если ИменаВидов.Количество() > 0 Тогда
		ПараметрыВызова.Вставить("ИменаВидов", ИменаВидов);
	КонецЕсли;

	Если ТипЗнч(ПорогПроцент) = Тип("Число") И ПорогПроцент > 0 Тогда
		ПараметрыВызова.Вставить("ПорогПрореживанияПроцент", ПорогПроцент);
	КонецЕсли;

	Если ЗначениеЗаполнено(КаталогВыгрузки) Тогда
		ПараметрыВызова.Вставить("КаталогВыгрузки", КаталогВыгрузки);
	КонецЕсли;

	Результат = РеквизитФормыВЗначение("Объект").СформироватьКарту(ПараметрыВызова);
	Возврат ?(Результат["успех"] = Истина, Строка(Результат["файл"]), "");

КонецФункции

#КонецОбласти
