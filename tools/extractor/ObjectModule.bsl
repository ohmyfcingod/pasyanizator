// П2.2: заполненность доп.реквизитов вида по живым данным. Возвращает Соответствие:
// "всего" -> документов вида; <uuid свойства> -> Структура(Заполнено, МаксДлина).
// «Заполнено» = есть строка ТЧ ДопРеквизиты С РЕАЛЬНЫМ значением. ЗАР (ревью Пакета 5, дед):
// БСП при очистке доп.реквизита НЕ всегда удаляет строку ТЧ — остаётся Значение="" / Неопределено;
// без фильтра такая пустышка засчиталась бы заполненной и пробила автопорог мусором на живой базе.
// МаксДлина — только по строковым значениям (З9: язык запросов длину не умеет).
Функция СтатистикаЗаполненности(Вид)

	Результат = Новый Соответствие;

	//@skip-check query-in-loop
	ЗапросВсего = Новый Запрос(
	"ВЫБРАТЬ КОЛИЧЕСТВО(Д.Ссылка) КАК Всего
	|ИЗ Справочник.ДокументыПредприятия КАК Д
	|ГДЕ Д.ВидДокумента = &Вид И НЕ Д.ПометкаУдаления");
	ЗапросВсего.УстановитьПараметр("Вид", Вид);
	ВыборкаВсего = ЗапросВсего.Выполнить().Выбрать();
	ВыборкаВсего.Следующий();
	Результат.Вставить("всего", ВыборкаВсего.Всего);

	//@skip-check query-in-loop
	ЗапросЗаполнено = Новый Запрос(
	"ВЫБРАТЬ ДР.Свойство КАК Свойство, КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДР.Ссылка) КАК Заполнено
	|ИЗ Справочник.ДокументыПредприятия.ДополнительныеРеквизиты КАК ДР
	|ГДЕ ДР.Ссылка.ВидДокумента = &Вид И НЕ ДР.Ссылка.ПометкаУдаления
	|	И ДР.Значение <> """" И ДР.Значение <> НЕОПРЕДЕЛЕНО
	|СГРУППИРОВАТЬ ПО ДР.Свойство");
	ЗапросЗаполнено.УстановитьПараметр("Вид", Вид);
	ВыборкаЗаполнено = ЗапросЗаполнено.Выполнить().Выбрать();
	Пока ВыборкаЗаполнено.Следующий() Цикл
		Инфо = Новый Структура("Заполнено, МаксДлина", ВыборкаЗаполнено.Заполнено, 0);
		Результат.Вставить(Строка(ВыборкаЗаполнено.Свойство.УникальныйИдентификатор()), Инфо);
	КонецЦикла;

	//@skip-check query-in-loop
	ЗапросСтрок = Новый Запрос(
	"ВЫБРАТЬ ДР.Свойство КАК Свойство, ДР.Значение КАК Значение
	|ИЗ Справочник.ДокументыПредприятия.ДополнительныеРеквизиты КАК ДР
	|ГДЕ ДР.Ссылка.ВидДокумента = &Вид И НЕ ДР.Ссылка.ПометкаУдаления
	|	И ТИПЗНАЧЕНИЯ(ДР.Значение) = ТИП(СТРОКА)");
	ЗапросСтрок.УстановитьПараметр("Вид", Вид);
	ВыборкаСтрок = ЗапросСтрок.Выполнить().Выбрать();
	Пока ВыборкаСтрок.Следующий() Цикл
		Инфо = Результат[Строка(ВыборкаСтрок.Свойство.УникальныйИдентификатор())];
		Если Инфо <> Неопределено Тогда
			Инфо.МаксДлина = Макс(Инфо.МаксДлина, СтрДлина(ВыборкаСтрок.Значение));
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Такт 5: статистика заполненности СВЕДЕНИЙ по НЕЗАВИСИМОМУ РС ДополнительныеСведения (не по ТЧ).
// <uuid свойства> -> Структура(Заполнено, МаксДлина). ВНУТРЕННЕЕ СОЕДИНЕНИЕ к документам вида
// (не навигация .Объект.ВидДокумента — составное измерение без индекса = полный скан глобального
// РС на КОРП-базе). Фильтр грязного EAV (Значение<>""/Неопределено) — как у реквизитов (Пакет 5).
Функция СтатистикаСведений(Вид)

	Результат = Новый Соответствие;

	//@skip-check query-in-loop
	ЗапросЗаполнено = Новый Запрос(
	"ВЫБРАТЬ ДопСвед.Свойство КАК Свойство, КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДопСвед.Объект) КАК Заполнено
	|ИЗ РегистрСведений.ДополнительныеСведения КАК ДопСвед
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДокументыПредприятия КАК Д
	|	ПО ДопСвед.Объект = Д.Ссылка
	|ГДЕ Д.ВидДокумента = &Вид И НЕ Д.ПометкаУдаления
	|	И ДопСвед.Значение <> """" И ДопСвед.Значение <> НЕОПРЕДЕЛЕНО
	|СГРУППИРОВАТЬ ПО ДопСвед.Свойство");
	ЗапросЗаполнено.УстановитьПараметр("Вид", Вид);
	ВыборкаЗаполнено = ЗапросЗаполнено.Выполнить().Выбрать();
	Пока ВыборкаЗаполнено.Следующий() Цикл
		Инфо = Новый Структура("Заполнено, МаксДлина", ВыборкаЗаполнено.Заполнено, 0);
		Результат.Вставить(Строка(ВыборкаЗаполнено.Свойство.УникальныйИдентификатор()), Инфо);
	КонецЦикла;

	//@skip-check query-in-loop
	ЗапросСтрок = Новый Запрос(
	"ВЫБРАТЬ ДопСвед.Свойство КАК Свойство, ДопСвед.Значение КАК Значение
	|ИЗ РегистрСведений.ДополнительныеСведения КАК ДопСвед
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДокументыПредприятия КАК Д
	|	ПО ДопСвед.Объект = Д.Ссылка
	|ГДЕ Д.ВидДокумента = &Вид И НЕ Д.ПометкаУдаления
	|	И ТИПЗНАЧЕНИЯ(ДопСвед.Значение) = ТИП(СТРОКА)");
	ЗапросСтрок.УстановитьПараметр("Вид", Вид);
	ВыборкаСтрок = ЗапросСтрок.Выполнить().Выбрать();
	Пока ВыборкаСтрок.Следующий() Цикл
		Инфо = Результат[Строка(ВыборкаСтрок.Свойство.УникальныйИдентификатор())];
		Если Инфо <> Неопределено Тогда
			Инфо.МаксДлина = Макс(Инфо.МаксДлина, СтрДлина(ВыборкаСтрок.Значение));
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// П2.3: ручные переопределения решений прореживания (зона 3): Соответствие
// <uuid свойства> -> Булево (Истина = тащить принудительно, Ложь = в EAV принудительно).
// Хранится ОбщегоНазначения.ХранилищеОбщихНастроекСохранить("Пасьянизатор","РешенияПрореживания").
Функция РешенияПрореживания()

	Попытка
		Сохранённые = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
			"Пасьянизатор", "РешенияПрореживания");
		Если ТипЗнч(Сохранённые) = Тип("Соответствие") Тогда
			Возврат Сохранённые;
		КонецЕсли;
	Исключение
		// настроек нет/недоступны — работаем автопорогом
	КонецПопытки;
	Возврат Новый Соответствие;

КонецФункции

Процедура ДобавитьПредупреждениеРеквизита(Реквизит, Контекст, Текст)

	Реквизит["предупреждения"].Добавить(Текст);
	Контекст.Предупреждений = Контекст.Предупреждений + 1;

КонецПроцедуры

// П2.1: срез uuid-хвоста «_<32 hex>» с конца имени ПВХ (ДО3 клеит такие при дублях заголовков)
Функция СрезатьUuidХвост(Знач Имя)

	Если СтрДлина(Имя) > 33 Тогда
		Хвост = НРег(Прав(Имя, 33));
		Если Лев(Хвост, 1) = "_" Тогда
			ЭтоHex = Истина;
			Для Позиция = 2 По 33 Цикл
				Если СтрНайти("0123456789abcdef", Сред(Хвост, Позиция, 1)) = 0 Тогда
					ЭтоHex = Ложь;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если ЭтоHex Тогда
				Возврат Лев(Имя, СтрДлина(Имя) - 33);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Возврат Имя;

КонецФункции

Функция НормализоватьИмя(Знач Строка)

	Результат = "";
	НоваяБуква = Истина;
	Для Позиция = 1 По СтрДлина(Строка) Цикл
		Символ = Сред(Строка, Позиция, 1);
		Код = КодСимвола(Символ);
		Допустим = (Код >= 48 И Код <= 57) ИЛИ (Код >= 65 И Код <= 90)
			ИЛИ (Код >= 97 И Код <= 122) ИЛИ (Код >= 1040 И Код <= 1103)
			ИЛИ Код = 1025 ИЛИ Код = 1105 ИЛИ Код = 95;
		Если НЕ Допустим Тогда
			НоваяБуква = Истина;
			Продолжить;
		КонецЕсли;
		Если НоваяБуква Тогда
			Результат = Результат + ВРег(Символ);
		Иначе
			Результат = Результат + Символ;
		КонецЕсли;
		НоваяБуква = Ложь;
	КонецЦикла;
	Если СтрДлина(Результат) > 0 Тогда
		ПервыйКод = КодСимвола(Лев(Результат, 1));
		Если ПервыйКод >= 48 И ПервыйКод <= 57 Тогда
			Результат = "П" + Результат;
		КонецЕсли;
	КонецЕсли;
	Возврат Лев(Результат, 64);

КонецФункции

#КонецОбласти

#КонецЕсли
