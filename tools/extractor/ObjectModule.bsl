// ПасьянизаторЭкстрактор — внешняя обработка: снимает JSON-карту EAV-модели видов документов
// (механизм дополнительных реквизитов и сведений БСП) для последующей генерации физических справочников.
//
// Вызов кодом/из консоли (без формы):
//   Результат = ВнешниеОбработки.Создать(Путь, Ложь).СформироватьКарту(Параметры);
//   Параметры — Структура/Соответствие, необязательные ключи: ИменаВидов (Массив из Строка; пусто =
//   автоподбор топ-N по числу доп.реквизитов), МаксВидов (Число, 3), ПорогПрореживанияПроцент (Число, 1),
//   КаталогВыгрузки (Строка). Возврат — Соответствие {успех, файл, видов, сообщение} (чтение по ключу).
//
// Экспортные методы: СформироватьКарту(ПараметрыВызова) — карта в JSON (schemaVersion 1.2);
//   ДанныеВитрины() — лёгкий обзор видов без тяжёлых запросов статистики.
//
// Компилируется без прямых ссылок на прикладные типы (валидируется в пустом проекте внешних обработок),
// работает в привилегированном режиме. Во время выполнения обращается запросами к объектам
// 1С:Документооборот 3.x (ВидыДокументов, ДокументыПредприятия, НаборыДополнительныхРеквизитовИСведений,
// РегистрСведений.ДополнительныеСведения/НастройкиНумерации, Организации) и к модулю БСП ОбщегоНазначения —
// на иной конфигурации запросную часть надо адаптировать. Контракт карты — contract/ПасьянсКарта.schema.json.
//
// Комментарии в коде намеренно сохраняют историю решений (ЗАРы) — см. docs/ЗАРы.md.

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Формирует JSON-карту выбранных видов документов.
//
// Параметры:
//  ПараметрыВызова - Структура - необязательные ключи:
//    * ИменаВидов - Массив из Строка - наименования видов; пусто = топ-N по числу доп.реквизитов
//    * МаксВидов - Число - размер топа при автоподборе (по умолчанию 3)
//    * КаталогВыгрузки - Строка - куда писать JSON
//
// Возвращаемое значение:
//  Соответствие из КлючИЗначение - успех (Булево), файл (Строка), видов (Число), сообщение (Строка)
Функция СформироватьКарту(Знач ПараметрыВызова = Неопределено) Экспорт

	УстановитьПривилегированныйРежим(Истина);

	Результат = Новый Соответствие;
	Результат.Вставить("успех", Ложь);

	Параметры = ПодготовитьПараметры(ПараметрыВызова);

	РеквизитыВидов = РеквизитыПоВидам();
	СведенияВидов = СведенияПоВидам(); // такт 5: свойства-сведения из ОТДЕЛЬНОЙ ТЧ набора
	НенайденныеИмена = Новый Массив;
	ВыбранныеВиды = ВыбратьВиды(РеквизитыВидов, Параметры, НенайденныеИмена);
	Если ВыбранныеВиды.Количество() = 0 Тогда
		Результат.Вставить("сообщение", "Не выбрано ни одного вида (проверьте ИменаВидов)");
		Возврат Результат;
	КонецЕсли;

	Контекст = Новый Структура;
	Контекст.Вставить("Предупреждений", 0);
	Контекст.Вставить("КоллизийРазрешено", 0);
	Контекст.Вставить("Коллизии", Новый Массив);
	Контекст.Вставить("БанкТипов", Новый Соответствие);
	Контекст.Вставить("ИменаСправочников", Новый Соответствие);
	Контекст.Вставить("ПорогПроцент", Параметры.ПорогПрореживанияПроцент);

	Виды = Новый Массив;
	ВсегоРеквизитов = 0;
	ВсегоEAV = 0;
	ВсегоСведений = 0;
	ВсегоСведенийТащим = 0;
	ВсегоСведенийВРС = 0;
	Для Каждого Вид Из ВыбранныеВиды Цикл
		//@skip-check query-in-loop
		ОписаниеВида = ОписаниеВида(Вид, РеквизитыВидов[Вид], СведенияВидов[Вид], Контекст);
		Виды.Добавить(ОписаниеВида);
		ВсегоРеквизитов = ВсегоРеквизитов + ОписаниеВида["реквизиты"].Количество();
		ВсегоEAV = ВсегоEAV + ОписаниеВида["остаютсяВEAV"].Количество();
		Для Каждого Свед Из ОписаниеВида["допСведения"] Цикл
			ВсегоСведений = ВсегоСведений + 1;
			Если Свед["решение"] = "реквизитОбъекта" Тогда
				ВсегоСведенийТащим = ВсегоСведенийТащим + 1;
			Иначе
				ВсегоСведенийВРС = ВсегоСведенийВРС + 1;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	Итоги = Новый Соответствие;
	Итоги.Вставить("видовВыбрано", Виды.Количество());
	Итоги.Вставить("реквизитовТащим", ВсегоРеквизитов);
	Итоги.Вставить("реквизитовВEAV", ВсегоEAV);
	Итоги.Вставить("сведенийВсего", ВсегоСведений);
	Итоги.Вставить("сведенийТащим", ВсегоСведенийТащим);
	Итоги.Вставить("сведенийВРС", ВсегоСведенийВРС);
	Итоги.Вставить("предупреждений", Контекст.Предупреждений + НенайденныеИмена.Количество());
	Итоги.Вставить("коллизийРазрешено", Контекст.КоллизийРазрешено);

	Экстрактор = Новый Соответствие;
	Экстрактор.Вставить("версия", "1.4-такт5П4");
	Экстрактор.Вставить("дата", Формат(ТекущаяДатаСеанса(), "ДФ=yyyy-MM-ddTHH:mm:ss"));
	Экстрактор.Вставить("база", Метаданные.Имя);
	Экстрактор.Вставить("версияКонфы", Метаданные.Версия);

	БанкТипов = Новый Массив;
	Для Каждого Элемент Из Контекст.БанкТипов Цикл
		БанкТипов.Добавить(Элемент.Ключ);
	КонецЦикла;

	Карта = Новый Соответствие;
	Карта.Вставить("schemaVersion", "1.2");
	Карта.Вставить("предупрежденияВыбора", НенайденныеИмена);
	Карта.Вставить("экстрактор", Экстрактор);
	Карта.Вставить("итоги", Итоги);
	Карта.Вставить("виды", Виды);
	Карта.Вставить("коллизии", Контекст.Коллизии);
	Карта.Вставить("банкТипов", БанкТипов);

	СоздатьКаталог(Параметры.КаталогВыгрузки);
	ИмяФайла = Параметры.КаталогВыгрузки + "\ПасьянсКарта_" + Метаданные.Имя + "_"
		+ Формат(ТекущаяДатаСеанса(), "ДФ=yyyy-MM-dd_HHmmss") + ".json";
	Запись = Новый ЗаписьJSON;
	Запись.ОткрытьФайл(ИмяФайла, "UTF-8", ,
		Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, " ", Истина));
	ЗаписатьJSON(Запись, Карта);
	Запись.Закрыть();

	Результат.Вставить("успех", Истина);
	Результат.Вставить("файл", ИмяФайла);
	Результат.Вставить("видов", Виды.Количество());
	Результат.Вставить("сообщение", СтрШаблон("Карта: видов %1, реквизитов %2, предупреждений %3",
		Виды.Количество(), ВсегоРеквизитов, Контекст.Предупреждений));
	Возврат Результат;

КонецФункции

#КонецОбласти

// Зона 3 (такт 4, П2.7): лёгкий обзор видов для витрины — Вид/Реквизитов/Документов.
// Тяжёлые запросы (статистика заполненности, автопороги) остаются в СформироватьКарту.
Функция ДанныеВитрины() Экспорт

	УстановитьПривилегированныйРежим(Истина);
	Результат = Новый Массив;
	РеквизитыВидов = РеквизитыПоВидам();
	Для Каждого Элемент Из РеквизитыВидов Цикл
		ЗаписьВитрины = Новый Структура("Вид, Реквизитов, Документов",
			Строка(Элемент.Ключ), Элемент.Значение.Количество(), 0);
		//@skip-check query-in-loop
		Запрос = Новый Запрос(
		"ВЫБРАТЬ КОЛИЧЕСТВО(Д.Ссылка) КАК Всего
		|ИЗ Справочник.ДокументыПредприятия КАК Д
		|ГДЕ Д.ВидДокумента = &Вид И НЕ Д.ПометкаУдаления");
		Запрос.УстановитьПараметр("Вид", Элемент.Ключ);
		Выборка = Запрос.Выполнить().Выбрать();
		Выборка.Следующий();
		ЗаписьВитрины.Документов = Выборка.Всего;
		Результат.Добавить(ЗаписьВитрины);
	КонецЦикла;
	Возврат Результат;

КонецФункции

#Область СлужебныеПроцедурыИФункции

Функция ПодготовитьПараметры(Знач ПараметрыВызова)

	Параметры = Новый Структура;
	Параметры.Вставить("ИменаВидов", Неопределено);
	Параметры.Вставить("МаксВидов", 3);
	Параметры.Вставить("ПорогПрореживанияПроцент", 1);
	Параметры.Вставить("КаталогВыгрузки", КаталогВременныхФайлов() + "ПасьянсКарты");
	Если ПараметрыВызова <> Неопределено Тогда
		Для Каждого Ключ Из Параметры Цикл
			Значение = Неопределено;
			Если ТипЗнч(ПараметрыВызова) = Тип("Структура")
				И ПараметрыВызова.Свойство(Ключ.Ключ, Значение) И Значение <> Неопределено Тогда
				Параметры.Вставить(Ключ.Ключ, Значение);
			ИначеЕсли ТипЗнч(ПараметрыВызова) = Тип("Соответствие")
				И ПараметрыВызова[Ключ.Ключ] <> Неопределено Тогда
				Параметры.Вставить(Ключ.Ключ, ПараметрыВызова[Ключ.Ключ]);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат Параметры;

КонецФункции

// З2 Фазы 1: Вид -> доп.реквизиты через ТЧ набора свойств.
Функция РеквизитыПоВидам()

	// П2.4: ЛЕВОЕ соединение — вид БЕЗ доп.реквизитов тоже кандидат (генератор соберёт его
	// с одними дефолтными полями); INNER молча отрезал такие виды (поймано посевной «Справкой»)
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Виды.Ссылка КАК Вид,
	|	ДопРекв.НомерСтроки КАК Порядок,
	|	ДопРекв.Свойство КАК Свойство,
	|	ДопРекв.Свойство.Имя КАК ИмяСвойства,
	|	ДопРекв.Свойство.Заголовок КАК Заголовок,
	|	ДопРекв.Свойство.ТипЗначения КАК ТипЗначения,
	|	ДопРекв.Свойство.ЗаполнятьОбязательно КАК Обязательный,
	|	ДопРекв.Свойство.ЭтоДополнительноеСведение КАК ЭтоСведение,
	|	ДопРекв.Свойство.ВладелецДополнительныхЗначений КАК ВладелецЗначений,
	|	ДопРекв.Свойство.ИдентификаторДляФормул КАК ИдентификаторДляФормул
	|ИЗ
	|	Справочник.ВидыДокументов КАК Виды
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НаборыДополнительныхРеквизитовИСведений.ДополнительныеРеквизиты КАК ДопРекв
	|		ПО ДопРекв.Ссылка = Виды.НаборСвойств
	|			И НЕ ДопРекв.ПометкаУдаления
	|ГДЕ
	|	НЕ Виды.ЭтоГруппа
	|	И НЕ Виды.ПометкаУдаления
	|УПОРЯДОЧИТЬ ПО
	|	Вид, Порядок");

	РеквизитыВидов = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Список = РеквизитыВидов[Выборка.Вид];
		Если Список = Неопределено Тогда
			Список = Новый Массив;
			РеквизитыВидов.Вставить(Выборка.Вид, Список);
		КонецЕсли;
		Если Выборка.Свойство = NULL ИЛИ НЕ ЗначениеЗаполнено(Выборка.Свойство) Тогда
			Продолжить; // вид без доп.реквизитов: кандидат с пустым списком
		КонецЕсли;
		Описание = Новый Структура;
		Описание.Вставить("Свойство", Выборка.Свойство);
		Описание.Вставить("ИмяСвойства", Выборка.ИмяСвойства);
		Описание.Вставить("Заголовок", Выборка.Заголовок);
		Описание.Вставить("ТипЗначения", Выборка.ТипЗначения);
		Описание.Вставить("Обязательный", Выборка.Обязательный);
		Описание.Вставить("ЭтоСведение", Выборка.ЭтоСведение);
		Описание.Вставить("ВладелецЗначений", Выборка.ВладелецЗначений);
		Описание.Вставить("ИдентификаторДляФормул", Выборка.ИдентификаторДляФормул);
		Список.Добавить(Описание);
	КонецЦикла;
	Возврат РеквизитыВидов;

КонецФункции

// Такт 5: свойства-СВЕДЕНИЯ из ОТДЕЛЬНОЙ ТЧ набора (ДополнительныеСведения) — зеркало
// РеквизитыПоВидам, но джойн по .ДополнительныеСведения. Штатный ДО3 хранит сведения ЗДЕСЬ,
// а не в ДополнительныеРеквизиты, поэтому раньше экстрактор их вообще не видел (допСведения пуст).
Функция СведенияПоВидам()

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Виды.Ссылка КАК Вид,
	|	ДопСвед.НомерСтроки КАК Порядок,
	|	ДопСвед.Свойство КАК Свойство,
	|	ДопСвед.Свойство.Имя КАК ИмяСвойства,
	|	ДопСвед.Свойство.Заголовок КАК Заголовок,
	|	ДопСвед.Свойство.ТипЗначения КАК ТипЗначения,
	|	ДопСвед.Свойство.ЗаполнятьОбязательно КАК Обязательный,
	|	ДопСвед.Свойство.ЭтоДополнительноеСведение КАК ЭтоСведение,
	|	ДопСвед.Свойство.ВладелецДополнительныхЗначений КАК ВладелецЗначений,
	|	ДопСвед.Свойство.ИдентификаторДляФормул КАК ИдентификаторДляФормул
	|ИЗ
	|	Справочник.ВидыДокументов КАК Виды
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НаборыДополнительныхРеквизитовИСведений.ДополнительныеСведения КАК ДопСвед
	|		ПО ДопСвед.Ссылка = Виды.НаборСвойств
	|			И НЕ ДопСвед.ПометкаУдаления
	|ГДЕ
	|	НЕ Виды.ЭтоГруппа
	|	И НЕ Виды.ПометкаУдаления
	|УПОРЯДОЧИТЬ ПО
	|	Вид, Порядок");

	СведенияВидов = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Список = СведенияВидов[Выборка.Вид];
		Если Список = Неопределено Тогда
			Список = Новый Массив;
			СведенияВидов.Вставить(Выборка.Вид, Список);
		КонецЕсли;
		Если Выборка.Свойство = NULL ИЛИ НЕ ЗначениеЗаполнено(Выборка.Свойство) Тогда
			Продолжить; // вид без доп.сведений
		КонецЕсли;
		Описание = Новый Структура;
		Описание.Вставить("Свойство", Выборка.Свойство);
		Описание.Вставить("ИмяСвойства", Выборка.ИмяСвойства);
		Описание.Вставить("Заголовок", Выборка.Заголовок);
		Описание.Вставить("ТипЗначения", Выборка.ТипЗначения);
		Описание.Вставить("Обязательный", Выборка.Обязательный);
		Описание.Вставить("ЭтоСведение", Выборка.ЭтоСведение);
		Описание.Вставить("ВладелецЗначений", Выборка.ВладелецЗначений);
		Описание.Вставить("ИдентификаторДляФормул", Выборка.ИдентификаторДляФормул);
		Список.Добавить(Описание);
	КонецЦикла;
	Возврат СведенияВидов;

КонецФункции

Функция ВыбратьВиды(РеквизитыВидов, Параметры, НенайденныеИмена)

	Кандидаты = Новый ТаблицаЗначений;
	Кандидаты.Колонки.Добавить("Вид");
	Кандидаты.Колонки.Добавить("Реквизитов");
	Для Каждого Элемент Из РеквизитыВидов Цикл
		СтрокаКандидата = Кандидаты.Добавить();
		СтрокаКандидата.Вид = Элемент.Ключ;
		СтрокаКандидата.Реквизитов = Элемент.Значение.Количество();
	КонецЦикла;

	Выбранные = Новый Массив;
	Если ТипЗнч(Параметры.ИменаВидов) = Тип("Массив") И Параметры.ИменаВидов.Количество() > 0 Тогда
		Для Каждого Имя Из Параметры.ИменаВидов Цикл
			Найден = Ложь;
			Для Каждого СтрокаКандидата Из Кандидаты Цикл
				Если ВРег(Строка(СтрокаКандидата.Вид)) = ВРег(Имя) Тогда
					Выбранные.Добавить(СтрокаКандидата.Вид);
					Найден = Истина;
				КонецЕсли;
			КонецЦикла;
			// П2.5: ненайденное имя — НЕ молча (опечатка заказа всплывает в карте и счётчике)
			Если НЕ Найден Тогда
				НенайденныеИмена.Добавить("вид не найден: " + Имя);
			КонецЕсли;
		КонецЦикла;
	Иначе
		Кандидаты.Сортировать("Реквизитов Убыв");
		Для Каждого СтрокаКандидата Из Кандидаты Цикл
			Если Выбранные.Количество() >= Параметры.МаксВидов Тогда
				Прервать;
			КонецЕсли;
			Выбранные.Добавить(СтрокаКандидата.Вид);
		КонецЦикла;
	КонецЕсли;
	Возврат Выбранные;

КонецФункции

Функция ОписаниеВида(Вид, Знач СписокРеквизитов, Знач СписокСведений, Контекст)

	Если СписокРеквизитов = Неопределено Тогда
		СписокРеквизитов = Новый Массив;
	КонецЕсли;
	Если СписокСведений = Неопределено Тогда
		СписокСведений = Новый Массив;
	КонецЕсли;

	// Шапка вида: все поля, флаги = булевы колонки (не хардкодим 39 имён)
	Запрос = Новый Запрос("ВЫБРАТЬ * ИЗ Справочник.ВидыДокументов ГДЕ Ссылка = &Вид");
	Запрос.УстановитьПараметр("Вид", Вид);
	ТаблицаВида = Запрос.Выполнить().Выгрузить();
	СтрокаВида = ТаблицаВида[0];
	Флаги = Новый Соответствие;
	Для Каждого Колонка Из ТаблицаВида.Колонки Цикл
		// у иерархического справочника поля запроса имеют тип «Т + Null» (NULL у групп) —
		// Null игнорируем, флаг = единственный значимый тип Булево
		ЗначимыхТипов = 0;
		ЕстьБулево = Ложь;
		Для Каждого ТипКолонки Из Колонка.ТипЗначения.Типы() Цикл
			Если ТипКолонки = Тип("Null") Тогда
				Продолжить;
			КонецЕсли;
			ЗначимыхТипов = ЗначимыхТипов + 1;
			ЕстьБулево = ЕстьБулево ИЛИ ТипКолонки = Тип("Булево");
		КонецЦикла;
		Если ЕстьБулево И ЗначимыхТипов = 1 Тогда
			Флаги.Вставить(Колонка.Имя, СтрокаВида[Колонка.Имя] = Истина);
		КонецЕсли;
	КонецЦикла;
	Лог(СтрШаблон("вид %1: колонок %2, флагов %3", Строка(СтрокаВида.Наименование),
		ТаблицаВида.Колонки.Количество(), Флаги.Количество()));

	ВидUuid = Строка(Вид.УникальныйИдентификатор());
	Наименование = Строка(СтрокаВида.Наименование);

	// Имя справочника: нормализация + коллизии (метаданные конфы, свои, другие виды карты)
	ИмяСправочника = НормализоватьИмя(Наименование);
	ИмяСправочника = РазрешитьКоллизиюИмениСправочника(ИмяСправочника, ВидUuid, Контекст);

	ОписаниеСправочника = Новый Соответствие;
	ОписаниеСправочника.Вставить("имя", ИмяСправочника);
	ОписаниеСправочника.Вставить("синоним", Наименование);

	ОписаниеВидаБлок = Новый Соответствие;
	ОписаниеВидаБлок.Вставить("uuid", ВидUuid);
	// у ВидыДокументов может не быть кода/иерархии — колонки проверяем по факту
	Если ТаблицаВида.Колонки.Найти("Код") <> Неопределено Тогда
		ОписаниеВидаБлок.Вставить("код", Строка(СтрокаВида.Код));
	КонецЕсли;
	ОписаниеВидаБлок.Вставить("наименование", Наименование);
	Если ТаблицаВида.Колонки.Найти("Родитель") <> Неопределено Тогда
		ОписаниеВидаБлок.Вставить("родитель", Строка(СтрокаВида.Родитель));
	КонецЕсли;

	Классификатор = Новый Соответствие;
	Классификатор.Вставить("реквизит", "ВидДокумента");
	Классификатор.Вставить("тип", "CatalogRef.ВидыДокументов");
	Классификатор.Вставить("значение", ВидUuid);
	Контекст.БанкТипов.Вставить("CatalogRef.ВидыДокументов", Истина);

	// Реквизиты и доп.сведения
	Реквизиты = Новый Массив;
	ДопСведения = Новый Массив;
	ЗанятыеИмена = Новый Соответствие;
	Для Каждого Стоп Из СтопЛистРеквизитов() Цикл
		ЗанятыеИмена.Вставить(ВРег(Стоп), Истина);
	КонецЦикла;

	Для Каждого Описание Из СписокРеквизитов Цикл
		// ЭтоСведение-ветка здесь мертва: сведения лежат в ОТДЕЛЬНОЙ ТЧ набора и приходят
		// через СписокСведений (такт 5), а не смешаны с реквизитами — обрабатываются ниже
		Реквизиты.Добавить(ОписаниеРеквизита(Описание, ЗанятыеИмена, ИмяСправочника, Контекст));
	КонецЦикла;

	// П2.2/П2.3: статистика заполненности по живым данным (З3/З6/З9) + автопороги прореживания.
	// Приоритет решения: ручное переопределение (по uuid свойства) > автопорог; всего=0 —
	// ТАЩИМ с предупреждением (не режем вслепую)
	ОстаютсяВEAV = Новый Массив;
	СтатистикаВида = СтатистикаЗаполненности(Вид);
	ВсегоДокументов = СтатистикаВида["всего"];
	Переопределения = РешенияПрореживания();
	ОтобранныеРеквизиты = Новый Массив;
	Для Каждого Реквизит Из Реквизиты Цикл
		Инфо = СтатистикаВида[Реквизит["свойство"]];
		Заполнено = ?(Инфо = Неопределено, 0, Инфо.Заполнено);
		Статистика = Новый Соответствие;
		Статистика.Вставить("заполнено", Заполнено);
		Статистика.Вставить("всего", ВсегоДокументов);
		Если Инфо <> Неопределено И Инфо.МаксДлина > 0 Тогда
			Статистика.Вставить("максДлина", Инфо.МаксДлина);
			// З9: плановую заглушку Строка(1024) ужимаем по данным: макс(500, 2×максДлина).
			// ЖЁСТКИЙ ЛИМИТ SDBL (диагноз деда, накат-падение такта 5): ограниченная строка в 1С
			// максимум 1024 символа. EDT/Конфигуратор проглатывают <length>1356</length>, а
			// реструктуризация БД падает «Слишком большое значение описателя длины». Больше 1024 —
			// либо потолок 1024 (данные влезают), либо неограниченная строка LOB (данные >1024).
			// УДАР 1 деда (матрица смерти реструктуризации): (1) LOB нельзя ИНДЕКСИРОВАТЬ —
			// SQL не строит B-Tree по NVARCHAR(MAX), реструктуризация падает; при переводе в LOB
			// гасим индекс. (2) LOB ЗАПРЕЩЁН В СОСТАВНОМ типе — там строку жёстко каппим 1024
			// (миграция обрежет хвост), даже если данные длиннее.
			Составной = Реквизит["типы"].Количество() > 1;
			Для Каждого ОписаниеТипа Из Реквизит["типы"] Цикл
				Если ОписаниеТипа["вид"] = "Строка" И ОписаниеТипа["длина"] = 1024 Тогда
					Желаемая = Макс(500, Инфо.МаксДлина * 2);
					Если Инфо.МаксДлина > 1024 И НЕ Составной Тогда
						ОписаниеТипа.Вставить("вид", "СтрокаНеограниченная");
						ОписаниеТипа.Удалить("длина");
						Если Реквизит["индексировать"] = Истина Тогда
							Реквизит.Вставить("индексировать", Ложь);
							ДобавитьПредупреждениеРеквизита(Реквизит, Контекст,
								"индекс СНЯТ: неограниченная строка (LOB) не индексируется");
						КонецЕсли;
						ДобавитьПредупреждениеРеквизита(Реквизит, Контекст,
							"данные >1024 (макс " + Строка(Инфо.МаксДлина) + ") — неограниченная строка (LOB)");
					Иначе
						ОписаниеТипа.Вставить("длина", Мин(1024, Желаемая));
						ДобавитьПредупреждениеРеквизита(Реквизит, Контекст,
							"длина по данным: макс " + Строка(Инфо.МаксДлина)
							+ ?(Инфо.МаксДлина > 1024, " (составной → жёсткий потолок 1024, хвост обрежется)", ""));
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Реквизит.Вставить("статистика", Статистика);

		Решение = Переопределения[Реквизит["свойство"]];
		Тащим = Истина;
		Причина = "";
		Если Решение <> Неопределено Тогда
			Тащим = Решение = Истина;
			Причина = "переопределено-вручную";
		ИначеЕсли ВсегоДокументов = 0 Тогда
			ДобавитьПредупреждениеРеквизита(Реквизит, Контекст,
				"нет данных для решения (документов 0)");
		ИначеЕсли Заполнено * 100 < ВсегоДокументов * Контекст.ПорогПроцент Тогда
			Тащим = Ложь;
			Причина = СтрШаблон("пусто-по-данным (%1 из %2, порог %3%%)",
				Строка(Заполнено), Строка(ВсегоДокументов), Строка(Контекст.ПорогПроцент));
		КонецЕсли;

		Если Тащим Тогда
			ОтобранныеРеквизиты.Добавить(Реквизит);
		Иначе
			ЗаписьEAV = Новый Соответствие;
			ЗаписьEAV.Вставить("свойство", Реквизит["свойство"]);
			ЗаписьEAV.Вставить("имяПВХ", Реквизит["имяПВХ"]);
			ЗаписьEAV.Вставить("причина", Причина);
			ЗаписьEAV.Вставить("статистика", Статистика);
			// Предупреждения реквизита уже учтены в Контекст.Предупреждений (при построении).
			// Перенося реквизит в EAV, НЕ теряем их из карты — иначе итоги.предупреждений > факта
			// и счётный гейт G0 краснит валидную карту (пре-ревью такта 4, симметрия контракта).
			Если Реквизит["предупреждения"] <> Неопределено И Реквизит["предупреждения"].Количество() > 0 Тогда
				ЗаписьEAV.Вставить("предупреждения", Реквизит["предупреждения"]);
			КонецЕсли;
			ОстаютсяВEAV.Добавить(ЗаписьEAV);
			ДобавитьКоллизию(Контекст, "реквизит", ИмяСправочника,
				Реквизит["имяРеквизита"], "остаётсяВEAV", Причина);
		КонецЕсли;
	КонецЦикла;
	Реквизиты = ОтобранныеРеквизиты;

	// Доп.сведения (такт 5): значения в НЕЗАВИСИМОМ РС ДополнительныеСведения. Статистика — по РС.
	// ЗанятыеИмена уже несёт имена реквизитов — дедуп сведения против них (мина №4: сведение и
	// реквизит с одним именем в одном виде). Решение по умолчанию (реш. юзера, агрессивно):
	// реквизитОбъекта выше порога, остаётсяВРС ниже/по переопределению. Приземление (генерация
	// поля) — П3; здесь только КОНТУР ДАННЫХ (extractor↔РС↔манифест), поле не генерится.
	СтатистикаСвед = СтатистикаСведений(Вид);
	Для Каждого ОписаниеСвед Из СписокСведений Цикл
		Свед = ОписаниеРеквизита(ОписаниеСвед, ЗанятыеИмена, ИмяСправочника, Контекст);
		ИнфоСвед = СтатистикаСвед[Свед["свойство"]];
		ЗаполненоСвед = ?(ИнфоСвед = Неопределено, 0, ИнфоСвед.Заполнено);
		СтатБлокСвед = Новый Соответствие;
		СтатБлокСвед.Вставить("заполнено", ЗаполненоСвед);
		СтатБлокСвед.Вставить("всего", ВсегоДокументов);
		Если ИнфоСвед <> Неопределено И ИнфоСвед.МаксДлина > 0 Тогда
			СтатБлокСвед.Вставить("максДлина", ИнфоСвед.МаксДлина);
		КонецЕсли;
		Свед.Вставить("статистика", СтатБлокСвед);
		РешениеСвед = Переопределения[Свед["свойство"]];
		Если РешениеСвед <> Неопределено Тогда
			Свед.Вставить("решение", ?(РешениеСвед = Истина, "реквизитОбъекта", "остаётсяВРС"));
			Свед.Вставить("причина", "переопределено-вручную");
		ИначеЕсли ВсегоДокументов = 0 Тогда
			Свед.Вставить("решение", "остаётсяВРС");
			Свед.Вставить("причина", "нет данных для решения (документов 0)");
		ИначеЕсли ЗаполненоСвед * 100 < ВсегоДокументов * Контекст.ПорогПроцент Тогда
			Свед.Вставить("решение", "остаётсяВРС");
			Свед.Вставить("причина", СтрШаблон("пусто-по-данным (%1 из %2, порог %3%%)",
				Строка(ЗаполненоСвед), Строка(ВсегоДокументов), Строка(Контекст.ПорогПроцент)));
		Иначе
			Свед.Вставить("решение", "реквизитОбъекта");
			Свед.Вставить("причина", "");
		КонецЕсли;
		ДопСведения.Добавить(Свед);
	КонецЦикла;

	// Дефолтные поля по флагам (такт 1: минимальный набор, тащить = флаг; ТЧ пока не тащим)
	ДефолтныеПоля = Новый Массив;
	ДобавитьДефолтноеПоле(ДефолтныеПоля, Флаги, "ВестиУчетПоОрганизациям", "Организация", Ложь);
	ДобавитьДефолтноеПоле(ДефолтныеПоля, Флаги, "УчитыватьСуммуДокумента", "Сумма", Ложь);
	ДобавитьДефолтноеПоле(ДефолтныеПоля, Флаги, "ВестиУчетПоКонтрагентам", "Контрагенты", Истина);
	ДобавитьДефолтноеПоле(ДефолтныеПоля, Флаги, "ВестиУчетТоваровИУслуг", "Товары", Истина);
	ДобавитьДефолтноеПоле(ДефолтныеПоля, Флаги, "ВестиУчетСторон", "Стороны", Истина);
	Если Флаги["ВестиУчетПоОрганизациям"] = Истина Тогда
		Контекст.БанкТипов.Вставить("CatalogRef.Организации", Истина);
	КонецЕсли;

	// П2.2: статистика дефолтных полей по колонкам ДП (известные носители: Организация, Сумма)
	Для Каждого ДефолтноеПоле Из ДефолтныеПоля Цикл
		// ДефолтноеПоле — Соответствие (не Структура): читаем ключом, без Свойство()
		ИмяПоля = ДефолтноеПоле["имя"];
		Если ИмяПоля = "Организация" ИЛИ ИмяПоля = "Сумма" Тогда
			Попытка
				УсловиеЗаполнено = ?(ИмяПоля = "Организация",
					"Д.Организация <> ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)",
					"Д.Сумма <> 0");
				//@skip-check query-in-loop
				ЗапросПоля = Новый Запрос(
				"ВЫБРАТЬ КОЛИЧЕСТВО(Д.Ссылка) КАК Заполнено
				|ИЗ Справочник.ДокументыПредприятия КАК Д
				|ГДЕ Д.ВидДокумента = &Вид И НЕ Д.ПометкаУдаления И " + УсловиеЗаполнено);
				ЗапросПоля.УстановитьПараметр("Вид", Вид);
				ВыборкаПоля = ЗапросПоля.Выполнить().Выбрать();
				ВыборкаПоля.Следующий();
				СтатистикаПоля = Новый Соответствие;
				СтатистикаПоля.Вставить("заполнено", ВыборкаПоля.Заполнено);
				СтатистикаПоля.Вставить("всего", ВсегоДокументов);
				ДефолтноеПоле.Вставить("статистика", СтатистикаПоля);
			Исключение
				// статистика поля — информационная, отказ не валит карту
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;

	// такт 5 П4: приземлённое сведение (решение=реквизитОбъекта) физически лежит в колонке —
	// механизм свойств ему больше не нужен. Хвост = сведения, что ОСТАЛИСЬ в РС, + EAV-реквизиты.
	СведенийВРСВида = 0;
	Для Каждого Свед Из ДопСведения Цикл
		Если Свед["решение"] = "остаётсяВРС" Тогда
			СведенийВРСВида = СведенийВРСВида + 1;
		КонецЕсли;
	КонецЦикла;

	EavХвост = Новый Соответствие;
	// прореженные автопорогом реквизиты — тоже EAV-хвост (поймано гейтом G0 на карте v1.1)
	EavХвост.Вставить("нуженМеханизмСвойств",
		СведенийВРСВида > 0 ИЛИ ОстаютсяВEAV.Количество() > 0);
	EavХвост.Вставить("предопределённыйНабор", "Справочник_" + ИмяСправочника);

	Описание = Новый Соответствие;
	Описание.Вставить("вид", ОписаниеВидаБлок);
	Описание.Вставить("справочник", ОписаниеСправочника);
	Описание.Вставить("классификатор", Классификатор);
	Описание.Вставить("флаги", Флаги);
	Описание.Вставить("дефолтныеПоля", ДефолтныеПоля);
	Описание.Вставить("реквизиты", Реквизиты);
	Описание.Вставить("остаютсяВEAV", ОстаютсяВEAV);
	Описание.Вставить("допСведения", ДопСведения);
	Описание.Вставить("eavХвост", EavХвост);
	Описание.Вставить("нумерация", НумерацияВида(Вид));
	Описание.Вставить("стороны", Новый Массив);
	Описание.Вставить("ролиФайлов", Новый Массив);
	Описание.Вставить("зависимости", Новый Массив);
	Возврат Описание;

КонецФункции

Функция ОписаниеРеквизита(Описание, ЗанятыеИмена, ИмяСправочника, Контекст)

	// Имя: ПВХ.Имя -> ИдентификаторДляФормул -> нормализованный Заголовок.
	// П2.1: uuid-хвост «_hex32» (стиль ДО3) режем ДО нормализации — человекочитаемые колонки;
	// уникальность держит дедуп-цикл, uuid свойства и так лежит в поле «свойство» карты
	Кандидат = НормализоватьИмя(СрезатьUuidХвост(Строка(Описание.ИмяСвойства)));
	Если ПустаяСтрока(Кандидат) Тогда
		Кандидат = НормализоватьИмя(СрезатьUuidХвост(Строка(Описание.ИдентификаторДляФормул)));
	КонецЕсли;
	Если ПустаяСтрока(Кандидат) Тогда
		Кандидат = НормализоватьИмя(Строка(Описание.Заголовок));
	КонецЕсли;
	Если ПустаяСтрока(Кандидат) Тогда
		Кандидат = "Реквизит";
	КонецЕсли;

	Имя = Кандидат;
	Суффикс = 1;
	Пока ЗанятыеИмена[ВРег(Имя)] <> Неопределено Цикл
		Суффикс = Суффикс + 1;
		СтрокаСуффикса = Формат(Суффикс, "ЧГ=");
		// суффикс дедупа не должен выталкивать имя за лимит 64 имён метаданных (ревью П1)
		Имя = Лев(Кандидат, 64 - СтрДлина(СтрокаСуффикса)) + СтрокаСуффикса;
	КонецЦикла;
	Если Имя <> Кандидат Тогда
		ДобавитьКоллизию(Контекст, "реквизит", ИмяСправочника, Кандидат, Имя,
			?(ЗанятыеИмена[ВРег(Кандидат)] = Истина, "стоп-лист-или-дедуп", "дедуп-внутри-вида"));
	КонецЕсли;
	ЗанятыеИмена.Вставить(ВРег(Имя), Ложь);

	Предупреждения = Новый Массив;
	Типы = РазвернутьТипы(Описание.ТипЗначения, Предупреждения, Контекст);

	Списочный = Ложь;
	Для Каждого Т Из Типы Цикл
		СсылТип = Т["ссылочныйТип"];
		Если СсылТип <> Неопределено И СтрНайти(СсылТип, "ЗначенияСвойствОбъектов") > 0 Тогда
			Списочный = Истина;
		КонецЕсли;
	КонецЦикла;

	Реквизит = Новый Соответствие;
	Реквизит.Вставить("свойство", Строка(Описание.Свойство.УникальныйИдентификатор()));
	Реквизит.Вставить("имяПВХ", Строка(Описание.ИмяСвойства));
	Реквизит.Вставить("заголовок", Строка(Описание.Заголовок));
	Реквизит.Вставить("имяРеквизита", Имя);
	Реквизит.Вставить("типы", Типы);
	Реквизит.Вставить("индексировать", Ложь);
	Реквизит.Вставить("обязательный", Описание.Обязательный = Истина);
	Реквизит.Вставить("списочный", Списочный);
	// владелецЗначений: у свойства с общим списком значений (ВладелецДополнительныхЗначений
	// заполнен) значения хранятся под ЧУЖИМ владельцем — берём его uuid, иначе uuid самого
	// свойства. Раньше писался uuid свойства всегда → неверный владелец у общих списков (пре-ревью).
	ВладелецСписка = Описание.ВладелецЗначений;
	Если Списочный Тогда
		Если ЗначениеЗаполнено(ВладелецСписка) Тогда
			Реквизит.Вставить("владелецЗначений", Строка(ВладелецСписка.УникальныйИдентификатор()));
		Иначе
			Реквизит.Вставить("владелецЗначений", Строка(Описание.Свойство.УникальныйИдентификатор()));
		КонецЕсли;
	Иначе
		Реквизит.Вставить("владелецЗначений", Неопределено);
	КонецЕсли;
	Если Списочный Тогда
		Предупреждения.Добавить("списочный: нужен отбор ПараметрыВыбора по владельцу");
	КонецЕсли;
	Реквизит.Вставить("предупреждения", Предупреждения);
	Контекст.Предупреждений = Контекст.Предупреждений + Предупреждения.Количество();
	Возврат Реквизит;

КонецФункции

Функция РазвернутьТипы(ОписаниеТипов, Предупреждения, Контекст)

	Типы = Новый Массив;
	СоставнойТип = ОписаниеТипов.Типы().Количество() > 1;
	Для Каждого Тип Из ОписаниеТипов.Типы() Цикл
		Т = Новый Соответствие;
		Если Тип = Тип("Число") Тогда
			КЧ = ОписаниеТипов.КвалификаторыЧисла;
			Т.Вставить("вид", ?(КЧ.ДопустимыйЗнак = ДопустимыйЗнак.Неотрицательный,
				"ЧислоНеотрицательное", "Число"));
			Т.Вставить("разрядность", ?(КЧ.Разрядность = 0, 15, КЧ.Разрядность));
			Т.Вставить("точность", КЧ.РазрядностьДробнойЧасти);
		ИначеЕсли Тип = Тип("Строка") Тогда
			КС = ОписаниеТипов.КвалификаторыСтроки;
			Если КС.Длина = 0 И СоставнойТип Тогда
				// неограниченная строка в составном запрещена платформой -> Строка(500)
				Т.Вставить("вид", "Строка");
				Т.Вставить("длина", 500);
				Предупреждения.Добавить("неограниченная строка в составном типе -> Строка(500)");
			ИначеЕсли КС.Длина = 0 Тогда
				Т.Вставить("вид", "СтрокаНеограниченная");
			Иначе
				Т.Вставить("вид", "Строка");
				Т.Вставить("длина", КС.Длина);
			КонецЕсли;
		ИначеЕсли Тип = Тип("Дата") Тогда
			КД = ОписаниеТипов.КвалификаторыДаты;
			Т.Вставить("вид", ?(КД.ЧастиДаты = ЧастиДаты.Дата, "Дата", "ДатаВремя"));
		ИначеЕсли Тип = Тип("Булево") Тогда
			Т.Вставить("вид", "Булево");
		ИначеЕсли Тип = Тип("УникальныйИдентификатор") Тогда
			Т.Вставить("вид", "УникальныйИдентификатор");
		Иначе
			ОбъектМД = Метаданные.НайтиПоТипу(Тип);
			ИмяXML = ?(ОбъектМД = Неопределено, Неопределено, XMLИмяТипа(ОбъектМД.ПолноеИмя()));
			Если ИмяXML = Неопределено Тогда
				Предупреждения.Добавить("экзотический тип пропущен: " + Строка(Тип));
				Продолжить;
			КонецЕсли;
			Т.Вставить("вид", "Ссылка");
			Т.Вставить("ссылочныйТип", ИмяXML);
			Контекст.БанкТипов.Вставить(ИмяXML, Истина);
		КонецЕсли;
		Типы.Добавить(Т);
	КонецЦикла;
	Возврат Типы;

КонецФункции

Функция XMLИмяТипа(ПолноеИмя)

	Части = СтрРазделить(ПолноеИмя, ".");
	Если Части.Количество() <> 2 Тогда
		Возврат Неопределено;
	КонецЕсли;
	Префиксы = Новый Соответствие;
	Префиксы.Вставить("Справочник", "CatalogRef");
	Префиксы.Вставить("Документ", "DocumentRef");
	Префиксы.Вставить("Перечисление", "EnumRef");
	Префиксы.Вставить("ПланВидовХарактеристик", "ChartOfCharacteristicTypesRef");
	Префиксы.Вставить("БизнесПроцесс", "BusinessProcessRef");
	Префиксы.Вставить("Задача", "TaskRef");
	Префикс = Префиксы[Части[0]];
	Возврат ?(Префикс = Неопределено, Неопределено, Префикс + "." + Части[1]);

КонецФункции

Функция РазрешитьКоллизиюИмениСправочника(Знач Имя, ВидUuid, Контекст)

	Исходное = Имя;
	// коллизия с метаданными конфы (свои опознаются по комментарию).
	// Лимит 64 держится ВНУТРИ цикла (ревью П1 + скептики): суффикс не выталкивает имя за
	// лимит, а усечение не может вернуть занятое имя (занятость проверяется УЖЕ усечённого)
	Базовое = Лев(Имя, 64);
	Имя = Базовое;
	НомерПопытки = 0;
	Занято = Истина;
	Пока Занято Цикл
		Занято = Ложь;
		Найденный = Метаданные.Справочники.Найти(Имя);
		Если Найденный <> Неопределено Тогда
			Занято = СтрНайти(Найденный.Комментарий, "Пасьянизатор из вида " + ВидUuid) = 0;
		КонецЕсли;
		Если НЕ Занято Тогда
			Занято = Метаданные.Документы.Найти(Имя) <> Неопределено
				ИЛИ Метаданные.Перечисления.Найти(Имя) <> Неопределено
				ИЛИ Метаданные.ПланыВидовХарактеристик.Найти(Имя) <> Неопределено;
		КонецЕсли;
		Если НЕ Занято И Контекст.ИменаСправочников[ВРег(Имя)] <> Неопределено Тогда
			Занято = Истина; // дубль внутри карты
		КонецЕсли;
		Если Занято Тогда
			НомерПопытки = НомерПопытки + 1;
			Хвост = "Пс" + ?(НомерПопытки > 1, Формат(НомерПопытки, "ЧГ="), "");
			Имя = Лев(Базовое, 64 - СтрДлина(Хвост)) + Хвост;
		КонецЕсли;
	КонецЦикла;
	Если Имя <> Исходное Тогда
		ДобавитьКоллизию(Контекст, "справочник", Имя, Исходное, Имя, "занято-в-конфе-или-карте");
	КонецЕсли;
	Контекст.ИменаСправочников.Вставить(ВРег(Имя), Истина);
	Возврат Имя;

КонецФункции

Процедура ДобавитьКоллизию(Контекст, Уровень, ИмяВида, Было, Стало, Правило)

	Коллизия = Новый Соответствие;
	Коллизия.Вставить("уровень", Уровень);
	Коллизия.Вставить("вид", ИмяВида);
	Коллизия.Вставить("было", Было);
	Коллизия.Вставить("стало", Стало);
	Коллизия.Вставить("правило", Правило);
	Контекст.Коллизии.Добавить(Коллизия);
	Контекст.КоллизийРазрешено = Контекст.КоллизийРазрешено + 1;

КонецПроцедуры

Процедура ДобавитьДефолтноеПоле(ДефолтныеПоля, Флаги, ИмяФлага, ИмяПоля, ЭтоТЧ)

	Если Флаги[ИмяФлага] <> Истина Тогда
		Возврат;
	КонецЕсли;
	Поле = Новый Соответствие;
	Поле.Вставить(?(ЭтоТЧ, "тч", "имя"), ИмяПоля);
	// такт 1: реквизиты тащим по флагу, ТЧ пока не генерим
	Поле.Вставить("тащить", НЕ ЭтоТЧ);
	Поле.Вставить("источникФлага", ИмяФлага);
	ДефолтныеПоля.Добавить(Поле);

КонецПроцедуры

// З4 Фазы 1: нумерация вида (информационный блок, генератор не читает)
Функция НумерацияВида(Вид)

	// имя СтрокиНумерации: локаль «Нумерация» коллизирует с общим модулем ДО3 «Нумерация»
	СтрокиНумерации = Новый Массив;
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Н.Нумератор.Наименование КАК Нумератор,
	|	Н.СпособНумерации КАК СпособНумерации
	|ИЗ
	|	РегистрСведений.НастройкиНумерации КАК Н
	|ГДЕ
	|	Н.ВидДокумента = &Вид");
	Запрос.УстановитьПараметр("Вид", Вид);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаНумерации = Новый Соответствие;
		СтрокаНумерации.Вставить("нумератор", Строка(Выборка.Нумератор));
		СтрокаНумерации.Вставить("способНумерации", Строка(Выборка.СпособНумерации));
		СтрокиНумерации.Добавить(СтрокаНумерации);
	КонецЦикла;
	Возврат СтрокиНумерации;

КонецФункции

// Диагностический лог (метод «лог из интересных мест кода»); пишется в переносимый временный каталог.
Процедура Лог(Текст)

	Попытка
		Запись = Новый ЗаписьТекста(КаталогВременныхФайлов() + "Пасьянизатор-экстрактор.log",
			КодировкаТекста.UTF8, , Истина);
		Запись.ЗаписатьСтроку(Формат(ТекущаяДатаСеанса(), "ДФ='yyyy-MM-dd HH:mm:ss'")
			+ " | Экстрактор | " + Текст);
		Запись.Закрыть();
	Исключение
		// лог не должен ронять экстракцию
	КонецПопытки;

КонецПроцедуры

